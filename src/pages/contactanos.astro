---
import "../styles/global.css";
import Navbar from "../Components/navbar.astro";
import Footer from "../Components/footer.astro";

// Configuración de contacto
const whatsappNumber = "526648028869";
const emailAddress = "edgarbarajas94848@gmail.com";
const facebookUrl = "https://www.facebook.com/share/1KqF14Y3ao/"; // Reemplaza con tu link
const instagramUrl = "#"; // Reemplaza con tu link
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>SNZ | Contacto</title>
        <link rel="icon" href="/snz2.ico" />
    </head>
    <body>
        <Navbar />

        <main class="bg-white">
            <section
                class="relative h-[80vh] flex items-center justify-center overflow-hidden bg-gray-900"
            >
                <div class="absolute inset-0 z-0">
                    <img
                        src="sano.jpg"
                        class="w-full h-full object-cover opacity-80 scale-110 motion-safe:animate-[pulse_8s_infinite]"
                        alt="Campo de cultivo"
                    />
                    <div
                        class="absolute inset-0 bg-gradient-to-b from-black/40 via-gray-900/20 to-white"
                    >
                    </div>
                </div>

                <div class="relative z-10 text-center px-6 drop-shadow-2xl">
                    <h1
                        class="text-5xl md:text-7xl font-bold text-white tracking-tighter mb-4 drop-shadow-md"
                    >
                        Hablemos de <span
                            class="text-transparent bg-clip-text bg-gradient-to-r from-red-500 via-orange-400 to-pink-500"
                            >Negocios</span
                        >
                    </h1>
                    <p
                        class="text-white text-lg md:text-xl max-w-2xl mx-auto font-medium drop-shadow-sm"
                    >
                        Llevamos la frescura de Zamora al mundo. Elige tu canal
                        preferido y nos pondremos en contacto contigo.
                    </p>
                </div>
            </section>

            <section class="relative -mt-24 pb-32 z-20">
                <div class="max-w-7xl mx-auto px-6">
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                        
                        <a href={`https://wa.me/${whatsappNumber}`} target="_blank" class="group relative overflow-hidden rounded-3xl bg-white p-1 shadow-2xl transition-all hover:-translate-y-2">
                            <div class="absolute inset-0 bg-gradient-to-br from-green-400 to-green-600 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                            <div class="relative bg-white rounded-[22px] p-8 h-full flex flex-col items-center text-center">
                                <div class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-green-50 text-green-600 group-hover:bg-green-600 group-hover:text-white transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.588-5.946 0-6.556 5.332-11.888 11.888-11.888 3.176 0 6.161 1.237 8.404 3.484 2.247 2.247 3.484 5.232 3.484 8.404 0 6.556-5.332 11.888-11.888 11.888-2.003 0-3.96-.503-5.711-1.458l-6.289 1.683zm6.314-2.736c1.604.953 3.538 1.458 5.52 1.458 5.435 0 9.856-4.421 9.856-9.856 0-2.633-1.025-5.107-2.887-6.97s-4.337-2.887-6.97-2.887c-5.435 0-9.856 4.421-9.856 9.856 0 2.126.681 4.14 1.96 5.826l-1.036 3.784 3.883-1.011zm11.233-6.175c-.3-.15-1.771-.875-2.046-.975-.275-.1-.475-.15-.675.15s-.775.975-.95 1.175-.35.225-.65.075c-.3-.15-1.265-.467-2.41-1.488-.89-.793-1.49-1.773-1.665-2.075-.175-.3-.019-.462.13-.611.134-.133.3-.35.45-.525.15-.175.2-.3.3-.5s.05-.375-.025-.525-.675-1.625-.925-2.225c-.244-.588-.492-.507-.675-.516-.174-.008-.374-.01-.574-.01s-.525.075-.8.375c-.275.3-1.05 1.025-1.05 2.5s1.075 2.9 1.225 3.1c.15.2 2.115 3.23 5.125 4.53 2.13.92 3.29 1.04 4.115.93 1.24-.16 1.771-.875 2.046-1.625.275-.75.275-1.39.2-1.525-.075-.135-.275-.225-.575-.375z"/></svg>
                                </div>
                                <h3 class="text-xl font-bold text-gray-900 mb-2">WhatsApp</h3>
                                <p class="text-gray-500 text-sm mb-4">Chat directo y rápido.</p>
                                <span class="text-green-600 font-bold text-xs uppercase tracking-widest">Escribir →</span>
                            </div>
                        </a>

                        <a href={facebookUrl} target="_blank" class="group relative overflow-hidden rounded-3xl bg-white p-1 shadow-2xl transition-all hover:-translate-y-2">
                            <div class="absolute inset-0 bg-gradient-to-br from-blue-600 to-blue-800 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                            <div class="relative bg-white rounded-[22px] p-8 h-full flex flex-col items-center text-center">
                                <div class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-50 text-blue-700 group-hover:bg-blue-700 group-hover:text-white transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                                </div>
                                <h3 class="text-xl font-bold text-gray-900 mb-2">Facebook</h3>
                                <p class="text-gray-500 text-sm mb-4">Noticias y comunidad.</p>
                                <span class="text-blue-700 font-bold text-xs uppercase tracking-widest">Seguir →</span>
                            </div>
                        </a>

                        <a href={instagramUrl} target="_blank" class="group relative overflow-hidden rounded-3xl bg-white p-1 shadow-2xl transition-all hover:-translate-y-2">
                            <div class="absolute inset-0 bg-gradient-to-br from-purple-600 via-red-500 to-yellow-500 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                            <div class="relative bg-white rounded-[22px] p-8 h-full flex flex-col items-center text-center">
                                <div class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-pink-50 text-pink-600 group-hover:bg-gradient-to-br group-hover:from-purple-600 group-hover:to-orange-500 group-hover:text-white transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                                </div>
                                <h3 class="text-xl font-bold text-gray-900 mb-2">Instagram</h3>
                                <p class="text-gray-500 text-sm mb-4">Galería de frescura.</p>
                                <span class="text-pink-600 font-bold text-xs uppercase tracking-widest">Ver fotos →</span>
                            </div>
                        </a>

                        <a href={`mailto:${emailAddress}`} class="group relative overflow-hidden rounded-3xl bg-white p-1 shadow-2xl transition-all hover:-translate-y-2">
                            <div class="absolute inset-0 bg-gradient-to-br from-gray-700 to-black opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                            <div class="relative bg-white rounded-[22px] p-8 h-full flex flex-col items-center text-center">
                                <div class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-gray-50 text-gray-900 group-hover:bg-gray-900 group-hover:text-white transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                                </div>
                                <h3 class="text-xl font-bold text-gray-900 mb-2">Correo</h3>
                                <p class="text-gray-500 text-sm mb-4">Relaciones comerciales.</p>
                                <span class="text-gray-900 font-bold text-xs uppercase tracking-widest">Enviar mail →</span>
                            </div>
                        </a>
                    </div>
                </div>
            </section>

        </main>
        
        <section class="py-24 bg-white border-t border-gray-100">
            <div class="max-w-7xl mx-auto px-6">
                <div class="grid lg:grid-cols-2 gap-16 items-center">
                    <div class="space-y-8">
                        <div>
                            <span class="inline-block p-2 px-4 rounded-full bg-orange-50 text-orange-600 mb-6 uppercase tracking-widest text-[10px] font-bold border border-orange-100">
                                Nuestra Planta y Oficinas
                            </span>
                            <h2 class="text-4xl font-bold text-gray-900 tracking-tight mb-4">
                                En el corazón de la zona fresera.
                            </h2>
                            <p class="text-gray-600 text-lg leading-relaxed">
                                Estamos ubicados estratégicamente en Zamora para garantizar que la fruta pase del campo al proceso de congelación en el menor tiempo posible.
                            </p>
                        </div>

                        <div class="flex items-start gap-4">
                            <div class="h-12 w-12 rounded-xl bg-gray-900 flex items-center justify-center text-white shrink-0 shadow-lg">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                            </div>
                            <div>
                                <h4 class="font-bold text-gray-900">Dirección</h4>
                                <p class="text-gray-500">Av. San Miguel Arcangel 182, Campestre San José,<br/>CP 59640 Zamora de Hidalgo, Michoacán.</p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div class="h-12 w-12 rounded-xl bg-gray-100 flex items-center justify-center text-gray-900 shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                            </div>
                            <div>
                                <h4 class="font-bold text-gray-900">Horario de Atención</h4>
                                <p class="text-gray-500">Lunes a Viernes: 8:00 AM — 5:00 PM<br/>Sábados: 8:00 AM — 2:00 PM</p>
                            </div>
                        </div>
                    </div>

                    <div class="relative group">
                        <div class="absolute -inset-4 bg-gradient-to-tr from-gray-200 to-gray-50 rounded-[2rem] blur-2xl opacity-50 group-hover:opacity-80 transition duration-500"></div>
                        <div class="relative overflow-hidden rounded-3xl shadow-2xl border border-gray-200 h-[450px]">
                            <iframe 
                                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3744.135759160565!2d-102.2687256!3d20.2117549!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x842e5668631b09b5%3A0xe6700877983636f!2sAv%20San%20Miguel%20Arcangel%20182%2C%20Campestre%20San%20Jos%C3%A9%2C%2059640%20Zamora%20de%20Hidalgo%2C%20Mich.!5e0!3m2!1ses-419!2smx!4v1700000000000" 
                                class="w-full h-full border-0 grayscale hover:grayscale-0 transition-all duration-700" 
                                allowfullscreen="" 
                                loading="lazy">
                            </iframe>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <Footer />
    </body>
</html>

<style>
    html { scroll-behavior: smooth; }
    @keyframes pulse {
        0%, 100% { transform: scale(1.1); }
        50% { transform: scale(1.05); }
    }
</style>