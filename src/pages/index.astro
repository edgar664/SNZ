---
import "../styles/global.css";
// He comentado los componentes para que no carguen innecesariamente
// import Navbar from "../Components/navbar.astro";
// import Footer from "../Components/footer.astro";

// Los datos de fruits se quedan aquí guardados en el código, pero no se mostrarán.
const fruits = [
    { name: "Mango", ... }, // (Tus datos siguen aquí)
];
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>SyNZ | Sitio en Mantenimiento</title>
        <link rel="icon" href="/snz2.ico" />
    </head>

    <body class="bg-gray-50 text-gray-800 flex items-center justify-center min-h-screen">
        
        <div class="absolute inset-0 z-0">
            <img
                src="https://www.baltana.com/files/wallpapers-5/Raspberry-HD-Desktop-Wallpaper-16909.jpg"
                class="w-full h-full object-cover opacity-20 grayscale"
            />
        </div>

        <main class="relative z-10 max-w-2xl px-6 text-center">
            <div class="inline-block px-4 py-1.5 mb-6 text-xs font-bold tracking-[0.4em] uppercase bg-green-100 text-green-700 rounded-full">
                Próximamente
            </div>
            
            <h1 class="text-4xl md:text-6xl font-black mb-6 leading-tight text-gray-900">
                SANO Y NUTRITIVO <span class="text-green-600">ZAMORA</span>
            </h1>
            
            <div class="w-20 h-1 bg-green-500 mx-auto mb-8"></div>

            <p class="text-xl md:text-2xl text-gray-600 font-light italic mb-10">
                "Estamos renovando nuestra plataforma para ofrecerte la mejor calidad del campo directamente a tu negocio."
            </p>

            <p class="text-sm text-gray-400 uppercase tracking-widest">
                El sitio web se encuentra temporalmente fuera de servicio.
            </p>
        </main>

    </body>
</html>

<style>
    /* Mantenemos tu fuente y estética básica */
    body {
        font-family: system-ui, -apple-system, sans-serif;
    }
</style>