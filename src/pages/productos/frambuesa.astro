---
import "../../styles/global.css";
import Navbar from "../../Components/navbar.astro";
import Footer from "../../Components/footer.astro";

const fruits = [];
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>SNZ | Frambuesa</title>
    </head>
    <header>
        <Navbar />
    </header>
    <body>
        <!-- HERO -->
        <section
            class="relative h-[60vh] flex items-center justify-center text-center text-white overflow-hidden"
        >
            <!-- IMAGENES -->
            <div class="absolute inset-0">
                <img
                    src="https://www.baltana.com/files/wallpapers-5/Raspberry-HD-Desktop-Wallpaper-16909.jpg"
                    class="hero-img hero-slide active absolute inset-0 w-full h-full object-cover"
                />

                <img
                    src="https://verdecora.es/blog/wp-content/uploads/2018/01/guia-para-plantar-frambuesas.jpg"
                    class="hero-img hero-slide absolute inset-0 w-full h-full object-cover"
                />

                <img
                    src="https://www.fresondepalos.es/wp-content/uploads/2024/12/fdp-181224-Blog.jpg"
                    class="hero-img hero-slide absolute inset-0 w-full h-full object-cover"
                />
            </div>
        </section>
    </body>

    <section class="py-24 bg-gradient-to-b from-gray-50 to-white">
        <div class="max-w-7xl mx-auto px-6">
            <!-- Header -->
            <div
                class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 mb-16"
            >
                <h1 class="text-5xl font-semibold tracking-tight text-gray-800">
                    Frambuesa
                </h1>

                <div class="flex gap-3">
                    <button
                        class="px-5 py-2.5 bg-green-700 text-white rounded-full text-sm font-medium shadow-sm hover:bg-green-800 transition"
                    >
                        Frambuesa IQF
                    </button>

                    <button
                        class="px-5 py-2.5 border border-green-700 text-green-700 rounded-full text-sm font-medium hover:bg-green-50 transition"
                    >
                        Puré de Frambuesa
                    </button>
                </div>
            </div>

            <!-- Layout -->
            <div class="grid lg:grid-cols-2 gap-16 items-center">
                <!-- Imagen -->
                <div class="relative group">
                    <div
                        class="absolute -inset-4 bg-green-100/40 rounded-3xl blur-2xl opacity-40 group-hover:opacity-60 transition"
                    >
                    </div>

                    <img
                        src="https://www.pollococido.com.ar/wp-content/uploads/2019/10/3001-frambuesa-congeladas-IQF-gradoA-10x1kg-c-min.jpg"
                        alt="Frambuesa IQF"
                        class="relative rounded-2xl shadow-xl object-cover w-full"
                    />
                </div>

                <!-- Info -->
                <div class="max-w-xl">
                    <h2 class="text-3xl font-semibold text-green-700 mb-8">
                        Frambuesa IQF
                    </h2>

                    <div class="h-px bg-gray-200 mb-8"></div>

                    <div
                        class="flex items-center justify-between mb-10 text-sm"
                    >
                        <span class="text-gray-500">Presentación</span>

                        <span class="font-semibold text-gray-800 tracking-wide">
                            • FRAMBUESA 80/20 A°
                        </span>
                    </div>

                    <p class="text-gray-600 leading-relaxed mb-6">
                        Producto elaborado a partir de frambuesa variedad
                        Vannessa, Sumif y Erika en óptimas condiciones de
                        madurez. El proceso incluye congelación individual
                        rápida (IQF) y todas las cajas pasan por detector de
                        metales antes de almacenarse a -18°C.
                    </p>

                    <p class="text-gray-600 leading-relaxed">
                        El producto se procesa bajo buenas prácticas de
                        fabricación (BPM) y principios HACCP, garantizando un
                        producto libre de materiales extraños como vidrio,
                        madera, plástico o metal.
                    </p>
                </div>
            </div>
        </div>
    </section>
 <!-- PRODUCTO -->
        <section class="py-28 bg-gradient-to-b from-gray-50 to-white">
            <div class="max-w-7xl mx-auto px-6">
                <!-- TITULO -->
                <div class="mb-20 text-center">
                    <h2
                        class="text-4xl font-semibold tracking-tight text-gray-900 mb-6"
                    >
                        Frambuesa IQF
                    </h2>

                    <p class="text-gray-500 max-w-2xl mx-auto">
                        Producto congelado individualmente mediante tecnología
                        IQF que preserva textura, sabor y propiedades naturales.
                    </p>
                </div>

                <!-- GRID -->
                <div class="grid lg:grid-cols-2 gap-20 items-center">
                    <!-- IMAGEN -->
                    <div class="relative group">
                        <div
                            class="absolute -inset-6 bg-green-100/50 blur-3xl rounded-3xl opacity-40 group-hover:opacity-60 transition"
                        >
                        </div>

                        <img
                            src="https://www.pollococido.com.ar/wp-content/uploads/2019/10/3001-frambuesa-congeladas-IQF-gradoA-10x1kg-c-min.jpg"
                            class="relative rounded-2xl shadow-2xl w-full object-cover"
                        />
                    </div>

                    <!-- INFO -->
                    <div>
                        <div class="flex gap-3 mb-10">
                            <span
                                class="px-5 py-2 bg-green-700 text-white rounded-full text-sm"
                            >
                                IQF
                            </span>

                            <span
                                class="px-5 py-2 border border-green-700 text-green-700 rounded-full text-sm"
                            >
                                Puré
                            </span>
                        </div>

                        <h3 class="text-2xl font-semibold text-green-700 mb-6">
                            Presentación
                        </h3>

                        <div class="border-t border-gray-200 mb-8"></div>

                        <div class="grid grid-cols-2 gap-6 mb-12 text-sm">
                            <div>
                                <p class="text-gray-400">Clasificación</p>
                                <p class="font-semibold">Frambuesa 80/20 A°</p>
                            </div>

                            <div>
                                <p class="text-gray-400">Temperatura</p>
                                <p class="font-semibold">-18°C</p>
                            </div>

                            <div>
                                <p class="text-gray-400">Proceso</p>
                                <p class="font-semibold">IQF</p>
                            </div>

                            <div>
                                <p class="text-gray-400">Control</p>
                                <p class="font-semibold">Detector de metales</p>
                            </div>
                        </div>

                        <p class="text-gray-600 leading-relaxed mb-6">
                            Producto elaborado a partir de frambuesas de las
                            variedades Vannessa, Sumif y Erika seleccionadas en
                            su punto óptimo de madurez.
                        </p>

                        <p class="text-gray-600 leading-relaxed">
                            El proceso de congelación IQF permite conservar la
                            calidad natural del fruto. Todo el producto es
                            procesado bajo buenas prácticas de fabricación (BPM)
                            y bajo principios HACCP.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CALIDAD -->
        <section class="py-24 bg-white">
            <div class="max-w-6xl mx-auto px-6 text-center">
                <h3 class="text-3xl font-semibold mb-12">
                    Estándares de Calidad
                </h3>

                <div class="grid md:grid-cols-3 gap-10 text-gray-600">
                    <div
                        class="p-8 border rounded-2xl hover:shadow-lg transition"
                    >
                        <h4 class="font-semibold mb-2">BPM</h4>
                        <p>
                            Buenas prácticas de manufactura aplicadas en todo el
                            proceso.
                        </p>
                    </div>

                    <div
                        class="p-8 border rounded-2xl hover:shadow-lg transition"
                    >
                        <h4 class="font-semibold mb-2">HACCP</h4>
                        <p>
                            Control de puntos críticos para garantizar seguridad
                            alimentaria.
                        </p>
                    </div>

                    <div
                        class="p-8 border rounded-2xl hover:shadow-lg transition"
                    >
                        <h4 class="font-semibold mb-2">Exportación</h4>
                        <p>Producto preparado para mercados internacionales.</p>
                    </div>
                </div>
            </div>
        </section>


    <footer>
        <Footer />
    </footer>
</html>
<style>
    /* zoom suave */
    .hero-img {
        animation: heroZoom 30s ease-in-out infinite alternate;
    }

    /* fade slider */
    .hero-slide {
        opacity: 0;
        transition: opacity 2s ease;
    }

    .hero-slide.active {
        opacity: 1;
    }

    /* zoom animation */
    @keyframes heroZoom {
        0% {
            transform: scale(1);
        }
        100% {
            transform: scale(1.15);
        }
    }
</style>

<script>
    const slides = document.querySelectorAll(".hero-slide");
    let index = 0;

    setInterval(() => {
        slides[index].classList.remove("active");

        index = (index + 1) % slides.length;

        slides[index].classList.add("active");
    }, 7000);
</script>

