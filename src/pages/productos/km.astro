---
import "../../styles/global.css";
import Navbar from "../../Components/navbar.astro";
import Footer from "../../Components/footer.astro";
import Calidad from "../../Components/calidad.astro";

// Imagen del Kiwi (Pestaña inicial)
const kiwiImage = "/purekiwi.jpeg";
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>SNZ | Exóticos</title>
        <link rel="icon" href="/snz2.ico" />
    </head>

    <body>
        <Navbar />

        <section class="relative h-[60vh] flex items-center justify-center text-center text-white overflow-hidden">
            <div class="absolute inset-0">
                <img
                    src="https://www-assets.liebherr.com/media/bu-media/lhbu-hau/global/freshmag/kiwi/planting-kiwi-liebherr-story-169-600.webp"
                    class="hero-img hero-slide active absolute inset-0 w-full h-full object-cover"
                />
                <img
                    src="https://konekstrade.com/wp-content/uploads/2024/09/maracuya-scaled.jpg"
                    class="hero-img hero-slide absolute inset-0 w-full h-full object-cover"
                />
            </div>
        </section>

        <section class="py-28 bg-gradient-to-b from-gray-50 to-white overflow-hidden">
            <div class="max-w-7xl mx-auto px-6">
                <div class="mb-20">
                    <h2 id="display-title" class="text-4xl font-semibold tracking-tight text-gray-900 mb-6 transition-all duration-300">
                        Kiwi Seleccionado
                    </h2>
                </div>

                <div class="grid lg:grid-cols-2 gap-20 items-center">
                    <div class="relative group">
                        <div id="bg-glow" class="absolute -inset-6 bg-green-100/50 blur-3xl rounded-3xl opacity-40 group-hover:opacity-60 transition"></div>
                        <div class="relative overflow-hidden rounded-2xl shadow-2xl bg-gray-100 aspect-[4/3]">
                            <img
                                id="product-img"
                                src={kiwiImage}
                                alt="Kiwi"
                                class="w-full h-full object-cover transition-opacity duration-500"
                            />
                            <video
                                id="product-video"
                                src="/maracuya.mp4" 
                                autoplay
                                muted
                                loop
                                playsinline
                                class="hidden absolute inset-0 w-full h-full object-cover transition-opacity duration-500"
                            ></video>
                        </div>
                    </div>

                    <div>
                        <div class="flex gap-3 mb-10">
                            <button
                                id="btn-kiwi"
                                data-type="kiwi"
                                class="tab-btn px-5 py-2 rounded-full text-sm font-medium transition-all bg-green-700 text-white shadow-md"
                            >
                                Kiwi
                            </button>
                            <button
                                id="btn-maracuya"
                                data-type="maracuya"
                                class="tab-btn px-5 py-2 rounded-full text-sm font-medium transition-all border border-yellow-600 text-yellow-700 hover:bg-yellow-50"
                            >
                                Maracuyá
                            </button>
                        </div>

                        <h3 class="text-2xl font-semibold text-gray-800 mb-6">Especificaciones</h3>
                        <div class="border-t border-gray-200 mb-8"></div>

                        <div class="grid grid-cols-2 gap-6 mb-12 text-sm">
                            <div>
                                <p class="text-gray-400">Variedad</p>
                                <p id="spec-clasificacion" class="font-semibold text-gray-800">Kiwi Hayward</p>
                            </div>
                            <div>
                                <p class="text-gray-400">Temperatura</p>
                                <p class="font-semibold text-gray-800">-18°C / Fresco</p>
                            </div>
                            <div>
                                <p class="text-gray-400">Proceso</p>
                                <p id="spec-proceso" class="font-semibold text-gray-800">Corte Manual / IQF</p>
                            </div>
                            <div>
                                <p class="text-gray-400">Calidad</p>
                                <p class="font-semibold text-gray-800">Grado Exportación</p>
                            </div>
                        </div>

                        <p id="desc-1" class="text-gray-600 leading-relaxed mb-6">
                            Selección premium de frutas tropicales y exóticas, procesadas bajo estándares internacionales para mantener su frescura y valor nutricional.
                        </p>
                        <p id="desc-2" class="text-gray-600 leading-relaxed">
                            Nuestro kiwi mantiene su textura firme y sus semillas características intactas. Ideal para toppings, ensaladas y decoración de alta repostería.
                        </p>
                    </div>
                </div>
            </div>
        </section>
        
        <Calidad color="text-green-700" />
        <Footer />
    </body>
</html>

<style>
    .hero-img { animation: heroZoom 30s ease-in-out infinite alternate; }
    .hero-slide { opacity: 0; transition: opacity 2s ease; }
    .hero-slide.active { opacity: 1; }
    @keyframes heroZoom { 0% { transform: scale(1); } 100% { transform: scale(1.15); } }
    .opacity-0 { opacity: 0; }
</style>

<script>
    const productData = {
        kiwi: {
            title: "Kiwi Seleccionado",
            img: "/purekiwi.jpeg",
            clasificacion: "Kiwi Hayward",
            proceso: "Corte Manual / IQF",
            desc2: "Nuestro kiwi mantiene su textura firme y sus semillas características intactas. Ideal para toppings, ensaladas y decoración de alta repostería.",
            colorBtn: "bg-green-700",
            borderBtn: "border-green-700",
            textBtn: "text-green-700",
            hoverBtn: "hover:bg-green-50",
            glow: "bg-green-100/50",
            calidadColor: "text-green-700"
        },
        maracuya: {
            title: "Pulpa de Maracuyá",
            video: "/maracuya.mp4",
            clasificacion: "Passiflora Edulis",
            proceso: "Extracción mecánica",
            desc2: "Pulpa de maracuyá 100% pura, con o sin semilla. Aroma intenso y brix estandarizado para la industria de bebidas y concentrados de alta gama.",
            colorBtn: "bg-yellow-600",
            borderBtn: "border-yellow-600",
            textBtn: "text-yellow-700",
            hoverBtn: "hover:bg-yellow-50",
            glow: "bg-yellow-100/50",
            calidadColor: "text-yellow-700"
        },
    };

    const slides = document.querySelectorAll(".hero-slide");
    let slideIndex = 0;
    setInterval(() => {
        if(slides.length > 0) {
            slides[slideIndex].classList.remove("active");
            slideIndex = (slideIndex + 1) % slides.length;
            slides[slideIndex].classList.add("active");
        }
    }, 7000);

    const buttons = document.querySelectorAll(".tab-btn");
    const imgEl = document.getElementById("product-img") as HTMLImageElement;
    const videoEl = document.getElementById("product-video") as HTMLVideoElement;
    const titleEl = document.getElementById("display-title");
    const specClas = document.getElementById("spec-clasificacion");
    const specProc = document.getElementById("spec-proceso");
    const desc2El = document.getElementById("desc-2");
    const bgGlow = document.getElementById("bg-glow");

    buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
            const type = btn.getAttribute("data-type") as "kiwi" | "maracuya";
            const info = productData[type];

            buttons.forEach((b) => {
                b.className = "tab-btn px-5 py-2 rounded-full text-sm font-medium transition-all";
                if (b === btn) {
                    b.classList.add(info.colorBtn, "text-white", "shadow-md");
                } else {
                    const otherType = b.getAttribute("data-type") as "kiwi" | "maracuya";
                    const otherInfo = productData[otherType];
                    b.classList.add("border", otherInfo.borderBtn, otherInfo.textBtn, otherInfo.hoverBtn);
                }
            });

            imgEl.classList.add("opacity-0");
            videoEl.classList.add("opacity-0");

            setTimeout(() => {
                if (info.video) {
                    videoEl.src = info.video;
                    videoEl.classList.remove("hidden");
                    imgEl.classList.add("hidden");
                    videoEl.classList.remove("opacity-0");
                    videoEl.play();
                } else {
                    imgEl.src = info.img || "";
                    imgEl.classList.remove("hidden");
                    videoEl.classList.add("hidden");
                    videoEl.pause();
                    imgEl.classList.remove("opacity-0");
                }

                if (bgGlow) bgGlow.className = `absolute -inset-6 blur-3xl rounded-3xl opacity-40 group-hover:opacity-60 transition ${info.glow}`;
                if (titleEl) titleEl.innerText = info.title;
                if (specClas) specClas.innerText = info.clasificacion;
                if (specProc) specProc.innerText = info.proceso;
                if (desc2El) desc2El.innerText = info.desc2;
            }, 200);
        });
    });
</script>