---
import "../styles/global.css";
import Navbar from "../Components/navbar.astro";
import Footer from "../Components/footer.astro";

const stats = [
    { label: "Años", value: "9+", key: "Años" },
    { label: "Productos", value: "15+", key: "Productos" },
    { label: "Mercados", value: "10+", key: "Mercados" },
];
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>SNZ | Nosotros</title>
        <link rel="icon" href="/snz2.ico" />
    </head>

    <body class="bg-[#fdfdfd] selection:bg-green-200">
        <Navbar />

        <section
            class="relative h-[65vh] flex items-center justify-center text-center text-white overflow-hidden"
        >
            <div class="absolute inset-0">
                <img
                    src="sano.jpg"
                    class="hero-img hero-slide active absolute inset-0 w-full h-full object-cover"
                />
                <img
                    src="https://verdecora.es/blog/wp-content/uploads/2018/01/guia-para-plantar-frambuesas.jpg"
                    class="hero-img hero-slide absolute inset-0 w-full h-full object-cover"
                />
                <img
                    src="https://www.fresondepalos.es/wp-content/uploads/2024/12/fdp-181224-Blog.jpg"
                    class="hero-img hero-slide absolute inset-0 w-full h-full object-cover"
                />
            </div>

            <div
                class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-[#fdfdfd]"
            >
            </div>

            <div class="relative z-10 px-6">
                <span
                    class="inline-block px-4 py-1 mb-4 text-xs font-bold tracking-[0.3em] uppercase bg-white/20 backdrop-blur-md border border-white/30 rounded-full"
                    data-key="Trayectoria">Trayectoria y Confianza</span
                >
                <h1
                    class="text-5xl md:text-7xl font-black mb-6 leading-tight drop-shadow-2xl uppercase"
                    data-key="nosotros_empresa"
                >
                    Nosotros
                </h1>
            </div>
        </section>

        <main class="relative -mt-20 z-20">
            <section class="max-w-7xl mx-auto px-6 pb-20">
                <div
                    class="bg-white/70 backdrop-blur-2xl border border-white rounded-[3rem] p-8 md:p-16 shadow-[0_20px_50px_rgba(0,0,0,0.05)] overflow-hidden relative"
                >
                    <div
                        class="absolute -top-24 -right-24 w-64 h-64 bg-green-200/30 rounded-full blur-3xl"
                    >
                    </div>

                    <div
                        class="grid lg:grid-cols-2 gap-16 items-center relative z-10"
                    >
                        <div>
                            <span
                                class="text-green-600 font-bold tracking-widest text-sm mb-4 block uppercase"
                                data-key="Sobre Nosotros">Sobre Nosotros</span
                            >
                            <h2
                                class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-8 leading-tight"
                                data-key="¿Quiénes Somos?"
                            >
                                ¿Quiénes Somos?
                            </h2>

                            <div
                                class="space-y-6 text-gray-600 text-lg leading-relaxed italic"
                            >
                                <p data-key="Quienes_Somos_P1">
                                    Somos una empresa mexicana ubicada en Zamora
                                    Michoacán, que inició operaciones en abril
                                    2017 como FRUTI ALVA. A través del tiempo,
                                    hemos logrado una expansión y consolidación
                                    de instalaciones que cumplen con las normas
                                    internacionales.
                                </p>
                                <p data-key="Quienes_Somos_P2">
                                    Hoy en día, somos <strong
                                        class="text-green-700"
                                        >SANO Y NUTRITIVO ZAMORA</strong
                                    >, empresa Certificada en SQF orientada a la
                                    comercialización y exportación de frutas y
                                    verduras en diversas presentaciones con
                                    inocuidad y mejor servicio.
                                </p>
                            </div>

                            <div
                                class="mt-10 flex items-center gap-5 p-6 bg-white/50 border border-white/80 rounded-[2rem] shadow-sm w-fit"
                            >
                                <div
                                    class="h-14 w-14 rounded-full bg-gradient-to-br from-green-500 to-green-700 flex items-center justify-center text-white text-xl font-bold shadow-lg"
                                >
                                    MLA
                                </div>
                                <div>
                                    <p
                                        class="font-bold text-gray-900 text-lg italic"
                                    >
                                        Miguel López Alvarado
                                    </p>
                                    <p
                                        class="text-xs text-green-600 font-bold uppercase tracking-tighter"
                                        data-key="Fundador"
                                    >
                                        Fundador y Director General
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="relative group">
                            <div
                                class="absolute -inset-2 bg-gradient-to-br from-green-400 to-emerald-600 rounded-[2.5rem] blur opacity-20 group-hover:opacity-40 transition duration-1000"
                            >
                            </div>
                            <img
                                src="snz.jpg"
                                class="relative rounded-[2rem] shadow-2xl w-full h-[550px] object-cover border border-white/50"
                            />
                        </div>
                    </div>
                </div>
            </section>

            <section class="py-24 relative overflow-hidden">
                <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-10">
                    <div
                        class="group p-1 bg-gradient-to-br from-white to-green-50 rounded-[3rem] shadow-2xl"
                    >
                        <div
                            class="bg-white/40 backdrop-blur-xl p-12 rounded-[2.9rem] border border-white h-full transition-all duration-500 group-hover:bg-white/10"
                        >
                            <div class="text-5xl mb-6">🌱</div>
                            <h3
                                class="text-3xl font-black text-gray-900 mb-6"
                                data-key="Misión"
                            >
                                Misión
                            </h3>
                            <p
                                class="text-gray-600 text-lg leading-relaxed"
                                data-key="Mision_Documento"
                            >
                                Ofrecer a nuestros clientes frutas y verduras
                                congeladas, asegurando que se cumplan los
                                estándares de calidad...
                            </p>
                        </div>
                    </div>

                    <div
                        class="group p-1 bg-gradient-to-br from-green-600 to-green-800 rounded-[3rem] shadow-2xl text-white"
                    >
                        <div
                            class="bg-green-700/20 backdrop-blur-xl p-12 rounded-[2.9rem] border border-white/20 h-full transition-all duration-500 group-hover:bg-black/10"
                        >
                            <div class="text-5xl mb-6">🌎</div>
                            <h3
                                class="text-3xl font-black mb-6"
                                data-key="Visión"
                            >
                                Visión
                            </h3>
                            <p
                                class="text-green-50 text-lg leading-relaxed opacity-90"
                                data-key="Vision_Documento"
                            >
                                Ser una empresa altamente competitiva y
                                reconocida a nivel internacional...
                            </p>
                        </div>
                    </div>
                </div>
            </section>
            <section class="py-20">
                <div class="max-w-5xl mx-auto px-6">
                    <div
                        class="bg-gradient-to-r from-green-800 to-green-600 rounded-[3rem] p-12 text-center text-white relative overflow-hidden"
                    >
                        <div class="absolute top-0 right-0 p-8 opacity-10">
                            <svg
                                width="200"
                                height="200"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"
                                ></path></svg
                            >
                        </div>
                        <h2
                            class="text-2xl md:text-3xl font-bold mb-6"
                            data-key="Política de Calidad e inocuidad"
                        >
                            Política de Calidad e inocuidad
                        </h2>
                        <p
                            class="text-xl text-green-50 italic font-light"
                            data-key="Politica_Desc"
                        >
                            "Nos comprometemos a trabajar, mantener y mejorar la
                            cultura de inocuidad, con la finalidad de procesar,
                            distribuir y comercializar nuestros productos que
                            garanticen el cumplimiento de las normas y
                            legislaciones vigentes."
                        </p>
                    </div>
                </div>
            </section>
            <section
                class="py-24 bg-gradient-to-b from-transparent to-green-50/50"
            >
                <div class="max-w-7xl mx-auto px-6">
                    <div class="text-center mb-20">
                        <h2
                            class="text-5xl font-black text-gray-900 mb-4 uppercase tracking-tighter"
                            data-key="Valores"
                        >
                            Filosofía Integral
                        </h2>
                        <div
                            class="h-1.5 w-24 bg-green-600 mx-auto rounded-full"
                        >
                        </div>
                    </div>

                    <div class="grid md:grid-cols-3 gap-6">
                        {
                            [
                                "Competitividad",
                                "Responsabilidad",
                                "Iniciativa",
                                "Confianza",
                                "Pasión",
                                "Ética",
                            ].map((val) => (
                                <div class="relative group cursor-default">
                                    <div class="absolute inset-0 bg-green-600 rounded-[2rem] translate-y-2 opacity-0 group-hover:opacity-100 transition-all duration-500 blur-xl" />
                                    <div class="relative bg-white/60 backdrop-blur-lg border border-white p-8 rounded-[2rem] shadow-sm hover:-translate-y-2 transition-all duration-500 h-full">
                                        <h4 class="text-xl font-bold text-green-800 mb-3 uppercase tracking-tight">
                                            {val}
                                        </h4>
                                        <p
                                            class="text-gray-500 text-sm leading-relaxed"
                                            data-key={`Valor_${val}`}
                                        >
                                            Descripción del valor enfocada a la
                                            excelencia y calidad...
                                        </p>
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </section>
        </main>

        <Footer />
    </body>
</html>

<style>
    /* Efecto Liquid Zoom en imágenes */
    .hero-img {
        animation: liquidMove 20s infinite alternate-reverse
            cubic-bezier(0.45, 0, 0.55, 1);
    }

    .hero-slide {
        opacity: 0;
        transition: opacity 2s ease-in-out;
    }
    .hero-slide.active {
        opacity: 1;
    }

    @keyframes liquidMove {
        0% {
            transform: scale(1) translateY(0);
        }
        100% {
            transform: scale(1.1) translateY(-20px);
        }
    }

    /* Scrollbar minimal */
    ::-webkit-scrollbar {
        width: 8px;
    }
    ::-webkit-scrollbar-track {
        background: #f1f1f1;
    }
    ::-webkit-scrollbar-thumb {
        background: #16a34a;
        border-radius: 10px;
    }
</style>

<script>
    const slides = document.querySelectorAll(".hero-slide");
    let index = 0;
    setInterval(() => {
        slides[index].classList.remove("active");
        index = (index + 1) % slides.length;
        slides[index].classList.add("active");
    }, 6000);
</script>
