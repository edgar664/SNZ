---
import "../styles/global.css";
import Navbar from "../Components/navbar.astro";
import Footer from "../Components/footer.astro";

// Configuración de contacto
const whatsappNumber = "526648028869"; // Reemplaza con el número real
const emailAddress = "edgarbarajas94848@gmail.com"; // Reemplaza con el correo real
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>SNZ | Contacto</title>
        <link rel="icon" href="/snz2.ico" />
    </head>
    <body>
        <Navbar />

        <main class="bg-white">
            <section
                class="relative h-[80vh] flex items-center justify-center overflow-hidden bg-gray-900"
            >
                <div class="absolute inset-0 z-0">
                    <img
                        src="sano.jpg"
                        class="w-full h-full object-cover opacity-80 scale-110 motion-safe:animate-[pulse_8s_infinite]"
                        alt="Campo de cultivo"
                    />
                    <div
                        class="absolute inset-0 bg-gradient-to-b from-black/40 via-gray-900/20 to-white"
                    >
                    </div>
                </div>

                <div class="relative z-10 text-center px-6 drop-shadow-2xl">
                    <h1
                        class="text-5xl md:text-7xl font-bold text-white tracking-tighter mb-4 drop-shadow-md"
                    >
                        Hablemos de <span
                            class="text-transparent bg-clip-text bg-gradient-to-r from-red-500 via-orange-400 to-pink-500"
                            >Negocios</span
                        >
                    </h1>
                    <p
                        class="text-white text-lg md:text-xl max-w-2xl mx-auto font-medium drop-shadow-sm"
                    >
                        Llevamos la frescura de Zamora al mundo. Elige tu canal
                        preferido y nos pondremos en contacto contigo.
                    </p>
                </div>
            </section>

            <section class="relative -mt-24 pb-32 z-20">
                <div class="max-w-6xl mx-auto px-6">
                    <div class="grid md:grid-cols-2 gap-8">
                        <a
                            href={`https://wa.me/${whatsappNumber}`}
                            target="_blank"
                            class="group relative overflow-hidden rounded-3xl bg-white p-1 shadow-2xl transition-all hover:-translate-y-2"
                        >
                            <div
                                class="absolute inset-0 bg-gradient-to-br from-green-400 to-green-600 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                            >
                            </div>
                            <div
                                class="relative bg-white rounded-[22px] p-10 h-full"
                            >
                                <div
                                    class="mb-8 inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-green-50 text-green-600 group-hover:bg-green-600 group-hover:text-white transition-colors duration-500"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-8 w-8"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.588-5.946 0-6.556 5.332-11.888 11.888-11.888 3.176 0 6.161 1.237 8.404 3.484 2.247 2.247 3.484 5.232 3.484 8.404 0 6.556-5.332 11.888-11.888 11.888-2.003 0-3.96-.503-5.711-1.458l-6.289 1.683zm6.314-2.736c1.604.953 3.538 1.458 5.52 1.458 5.435 0 9.856-4.421 9.856-9.856 0-2.633-1.025-5.107-2.887-6.97s-4.337-2.887-6.97-2.887c-5.435 0-9.856 4.421-9.856 9.856 0 2.126.681 4.14 1.96 5.826l-1.036 3.784 3.883-1.011zm11.233-6.175c-.3-.15-1.771-.875-2.046-.975-.275-.1-.475-.15-.675.15s-.775.975-.95 1.175-.35.225-.65.075c-.3-.15-1.265-.467-2.41-1.488-.89-.793-1.49-1.773-1.665-2.075-.175-.3-.019-.462.13-.611.134-.133.3-.35.45-.525.15-.175.2-.3.3-.5s.05-.375-.025-.525-.675-1.625-.925-2.225c-.244-.588-.492-.507-.675-.516-.174-.008-.374-.01-.574-.01s-.525.075-.8.375c-.275.3-1.05 1.025-1.05 2.5s1.075 2.9 1.225 3.1c.15.2 2.115 3.23 5.125 4.53 2.13.92 3.29 1.04 4.115.93 1.24-.16 1.771-.875 2.046-1.625.275-.75.275-1.39.2-1.525-.075-.135-.275-.225-.575-.375z"
                                        ></path></svg
                                    >
                                </div>
                                <h3
                                    class="text-2xl font-bold text-gray-900 mb-2"
                                >
                                    Respuesta Inmediata
                                </h3>
                                <p class="text-gray-500 mb-6">
                                    ¿Necesitas una cotización rápida o saber
                                    disponibilidad de stock? Escríbenos por
                                    WhatsApp.
                                </p>
                                <span
                                    class="inline-flex items-center text-green-600 font-semibold"
                                >
                                    Abrir chat directo
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-5 w-5 ml-2 group-hover:translate-x-2 transition-transform"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M17 8l4 4m0 0l-4 4m4-4H3"
                                        ></path></svg
                                    >
                                </span>
                            </div>
                        </a>

                        <a
                            href={`mailto:${emailAddress}`}
                            class="group relative overflow-hidden rounded-3xl bg-white p-1 shadow-2xl transition-all hover:-translate-y-2"
                        >
                            <div
                                class="absolute inset-0 bg-gradient-to-br from-gray-700 to-black opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                            >
                            </div>
                            <div
                                class="relative bg-white rounded-[22px] p-10 h-full"
                            >
                                <div
                                    class="mb-8 inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-gray-50 text-gray-900 group-hover:bg-gray-900 group-hover:text-white transition-colors duration-500"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-8 w-8"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                        ></path></svg
                                    >
                                </div>
                                <h3
                                    class="text-2xl font-bold text-gray-900 mb-2"
                                >
                                    Relación Comercial
                                </h3>
                                <p class="text-gray-500 mb-6">
                                    Para propuestas formales, exportación o
                                    alianzas estratégicas a largo plazo.
                                </p>
                                <span
                                    class="inline-flex items-center text-gray-900 font-semibold"
                                >
                                    Enviar correo formal
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-5 w-5 ml-2 group-hover:translate-x-2 transition-transform"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M17 8l4 4m0 0l-4 4m4-4H3"
                                        ></path></svg
                                    >
                                </span>
                            </div>
                        </a>
                    </div>
                </div>
            </section>
        </main>
        <section class="py-2 bg-white border-t border-gray-100">
            <div class="max-w-7xl mx-auto px-6">
                <div class="grid lg:grid-cols-2 gap-16 items-center">
                    <div class="space-y-8">
                        <div>
                            <span
                                class="inline-block p-2 px-4 rounded-full bg-orange-50 text-orange-600 mb-6 uppercase tracking-widest text-[10px] font-bold border border-orange-100"
                            >
                                Nuestra Planta y Oficinas
                            </span>
                            <h2
                                class="text-4xl font-bold text-gray-900 tracking-tight mb-4"
                            >
                                En el corazón de la zona fresera.
                            </h2>
                            <p class="text-gray-600 text-lg leading-relaxed">
                                Estamos ubicados estratégicamente en Zamora para
                                garantizar que la fruta pase del campo al
                                proceso de congelación en el menor tiempo
                                posible, preservando su calidad de exportación.
                            </p>
                        </div>

                        <div class="flex items-start gap-4">
                            <div
                                class="h-12 w-12 rounded-xl bg-gray-900 flex items-center justify-center text-white shrink-0 shadow-lg"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-6 w-6"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                    ></path><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                    ></path></svg
                                >
                            </div>
                            <div>
                                <h4 class="font-bold text-gray-900">
                                    Dirección
                                </h4>
                                <p class="text-gray-500">
                                    Av. San Miguel Arcangel 182, Campestre San
                                    José,<br />CP 59640 Zamora de Hidalgo,
                                    Michoacán.
                                </p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div
                                class="h-12 w-12 rounded-xl bg-gray-100 flex items-center justify-center text-gray-900 shrink-0"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-6 w-6"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                    ></path></svg
                                >
                            </div>
                            <div>
                                <h4 class="font-bold text-gray-900">
                                    Horario de Atención
                                </h4>
                                <p class="text-gray-500">
                                    Lunes a Viernes: 8:00 AM — 5:00 PM<br
                                    />Sábados: 8:00 AM — 2:00 PM
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="relative group">
                        <div
                            class="absolute -inset-4 bg-gradient-to-tr from-gray-200 to-gray-50 rounded-[2rem] blur-2xl opacity-50 group-hover:opacity-80 transition duration-500"
                        >
                        </div>
                        <div
                            class="relative overflow-hidden rounded-3xl shadow-2xl border border-gray-200 h-[450px]"
                        >
                            <iframe
                                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3744.1706686129846!2d-102.3025219!3d20.0159497!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x842e866e7465660b%3A0xc3f837637841c1b1!2sAv.%20San%20Miguel%20Arcangel%20182%2C%20Campestre%20San%20Jos%C3%A9%2C%2059640%20Zamora%20de%20Hidalgo%2C%20Mich.!5e0!3m2!1ses-419!2smx!4v1700000000000!5m2!1ses-419!2smx"
                                class="w-full h-full border-0 grayscale hover:grayscale-0 transition-all duration-700"
                                allowfullscreen=""
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade"
                            >
                            </iframe>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <Footer />
    </body>
</html>

<style>
    /* Estilo para suavizar el scroll si agregas anclas */
    html {
        scroll-behavior: smooth;
    }
    /* Animación sutil de respiración para la imagen de fondo */
    @keyframes pulse {
        0%,
        100% {
            transform: scale(1.1);
        }
        50% {
            transform: scale(1.05);
        }
    }
</style>
<!-- HERO -->
<section
    class="relative h-[87vh] flex items-center justify-center text-center text-white overflow-hidden"
>
    <!-- IMAGENES -->
    <div class="absolute inset-0">
        <img
            src="https://www.baltana.com/files/wallpapers-5/Raspberry-HD-Desktop-Wallpaper-16909.jpg"
            class="hero-img hero-slide active absolute inset-0 w-full h-full object-cover"
        />

        <img
            src="https://images.unsplash.com/photo-1464226184884-fa280b87c399"
            class="hero-img hero-slide absolute inset-0 w-full h-full object-cover"
        />

        <img
            src="https://images.unsplash.com/photo-1502741338009-cac2772e18bc"
            class="hero-img hero-slide absolute inset-0 w-full h-full object-cover"
        />
    </div>

    <!-- Overlay -->
    <div
        class="absolute inset-0 bg-gradient-to-b from-black/90 via-black/30 to-transparent"
    >
    </div>

    <!-- CONTENIDO -->
    <div class="relative max-w-3xl px-6">
        <h1 class="text-5xl md:text-6xl font-bold mb-6 leading-tight">
            Sano y Nutritivo Zamora S.A. de C.V.
        </h1>

        <p class="text-lg md:text-xl opacity-90 mb-8">
            Frutas frescas cultivadas con procesos naturales y sostenibles.
            Calidad del campo directamente a tu negocio.
        </p>
    </div>
</section>

<section class="relative py-2 bg-gradient-to-b from-green-50 to-white">
    <div class="max-w-6xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Kosher -->
            <div
                class="flex items-center gap-4 rounded-2xl px-6 py-5
                        bg-white/40 backdrop-blur-xl
                        border border-white/40
                        shadow-lg shadow-green-100/40
                        hover:bg-white/60 hover:shadow-xl
                        transition-all duration-300"
            >
                <div
                    class="w-11 h-11 flex items-center justify-center rounded-full bg-gradient-to-br from-green-400 to-green-600 shadow-md"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-6 h-6 text-white"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M20.285 6.709a1 1 0 010 1.414l-9.192 9.192a1 1 0 01-1.414 0L3.714 11.35a1 1 0 111.414-1.414l4.243 4.243 8.485-8.485a1 1 0 011.414 0z"
                            clip-rule="evenodd"></path>
                    </svg>
                </div>

                <div>
                    <h3 class="font-semibold text-gray-900">
                        Certificación Kosher
                    </h3>
                </div>
            </div>

            <!-- Primus -->
            <div
                class="flex items-center gap-4 rounded-2xl px-6 py-5
                        bg-white/40 backdrop-blur-xl
                        border border-white/40
                        shadow-lg shadow-green-100/40
                        hover:bg-white/60 hover:shadow-xl
                        transition-all duration-300"
            >
                <div
                    class="w-11 h-11 flex items-center justify-center rounded-full bg-gradient-to-br from-green-400 to-green-600 shadow-md"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-6 h-6 text-white"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M20.285 6.709a1 1 0 010 1.414l-9.192 9.192a1 1 0 01-1.414 0L3.714 11.35a1 1 0 111.414-1.414l4.243 4.243 8.485-8.485a1 1 0 011.414 0z"
                            clip-rule="evenodd"></path>
                    </svg>
                </div>

                <div>
                    <h3 class="font-semibold text-gray-900">
                        Certificación PrimusGFS
                    </h3>
                </div>
            </div>
        </div>
    </div>
</section>
