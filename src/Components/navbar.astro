<header class="fixed inset-x-0 top-0 z-30 w-full">
  <nav
    class="max-w-7xl mx-auto flex items-center justify-between px-8 py-4
bg-white/10 backdrop-blur-xl border border-white/20 rounded-b-3xl
shadow-[0_8px_32px_0_rgba(0,0,0,0.1)]
hover:shadow-[0_12px_48px_0_rgba(0,0,0,0.15)] transition-all duration-500"
  >
    <!-- IZQUIERDA -->
    <div class="w-1/3">
      <a
        href="/"
        class="text-3xl font-bold text-green-700 tracking-tight hover:text-green-600 transition"
      >
        S&N
      </a>
    </div>

    <!-- CENTRO LOGO -->
    <div class="w-1/3 flex justify-center">
      <img
        src="/snz2.ico"
        alt="Logo SNZ"
        class="h-20 w-20 rounded-full shadow-inner shadow-green-200/50"
      />
    </div>

    <!-- BOTON HAMBURGUESA SOLO MOVIL -->
    <div class="md:hidden flex justify-end w-1/3">
      <button
        id="menu-btn"
        class="text-3xl text-green-700 hover:text-green-600 transition"
      >
        ☰
      </button>
    </div>

    <!-- MENU ESCRITORIO -->
    <ul
      id="menu"
      class="hidden md:flex w-1/3 justify-end gap-8 text-sm font-medium items-center"
    >
      <li><a href="/" class="hover:text-green-600 transition">Inicio</a></li>

      <!-- DROPDOWN -->
      <li class="relative group">
        <button class="hover:text-green-600 transition flex items-center gap-1">
          Productos <span class="text-xs">▼</span>
        </button>

        <ul
          class="absolute top-full left-0 mt-2 w-48
bg-white/20 backdrop-blur-lg border border-white/30 rounded-3xl
shadow-[0_8px_32px_0_rgba(0,0,0,0.1)] opacity-0 invisible
group-hover:opacity-100 group-hover:visible transition-all duration-500"
        >
          <li>
            <a
              href="/productos/frambuesa"
              class="block px-4 py-2 hover:bg-green-100/40 rounded-xl transition"
              >Frambuesa</a>
          </li>
          <li>
            <a
              href="/productos/fresa"
              class="block px-4 py-2 hover:bg-green-100/40 rounded-xl transition"
              >Fresa</a>
          </li>
          <li>
            <a
              href="/productos/mango"
              class="block px-4 py-2 hover:bg-green-100/40 rounded-xl transition"
              >Mango</a>
          </li>
          <li>
            <a
              href="/productos/km"
              class="block px-4 py-2 hover:bg-green-100/40 rounded-xl transition"
              >Kiwi y Maracuya</a>
          </li>
        </ul>
      </li>

      <li>
        <a href="/nosotros" class="hover:text-green-600 transition">Nosotros</a>
      </li>
      <li>
        <a href="/contactanos" class="hover:text-green-600 transition"
          >Contacto</a>
      </li>
    </ul>
  </nav>

  <!-- MENU MOVIL -->
  <div
    id="mobile-menu"
    class="hidden md:hidden mt-2 mx-4
bg-white/10 backdrop-blur-xl border border-white/20
rounded-3xl shadow-[0_8px_32px_0_rgba(0,0,0,0.1)]"
  >
    <ul class="flex flex-col p-6 gap-4 text-sm font-medium">
      <li><a href="/" class="hover:text-green-600 transition">Inicio</a></li>

      <li>
        <button
          id="productos-btn"
          class="flex items-center justify-between w-full text-left hover:text-green-600 transition"
        >
          Productos <span>▼</span>
        </button>
        <ul id="productos-menu" class="hidden flex flex-col ml-4 mt-2 gap-2">
          <li>
            <a
              href="/productos/frambuesa"
              class="block hover:text-green-600 transition">Frambuesa</a>
          </li>
          <li>
            <a
              href="/productos/fresa"
              class="block hover:text-green-600 transition">Fresa</a>
          </li>
          <li>
            <a
              href="/productos/mango"
              class="block hover:text-green-600 transition">Mango</a>
          </li>
          <li>
            <a
              href="/productos/km"
              class="block hover:text-green-600 transition">Kiwi y Maracuya</a>
          </li>
        </ul>
      </li>

      <li>
        <a href="/nosotros" class="hover:text-green-600 transition">Nosotros</a>
      </li>
      <li>
        <a href="/contactanos" class="hover:text-green-600 transition"
          >Contacto</a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Toggle menu movil
  const btn = document.getElementById("menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  btn.addEventListener("click", () => mobileMenu.classList.toggle("hidden"));

  // Toggle submenu productos movil
  const productosBtn = document.getElementById("productos-btn");
  const productosMenu = document.getElementById("productos-menu");
  productosBtn.addEventListener("click", () =>
    productosMenu.classList.toggle("hidden"),
  );
</script>
